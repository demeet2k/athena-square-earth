  "cell_schema": {
    "BoardStateRow": {
      "version": "v2",
      "description": "One row of the runtime board: a single thread's state at one clock tick",
      "fields": {
        "thread_id": "str -- unique thread identifier",
        "clock_beat": "int -- master clock position (0-419)",
        "gate_status": "enum: OPEN | BLOCKED | SEALED",
        "sfcr_mask": "int (1-15) -- active SFCR element combination",
        "lens_state": "dict -- current 4-lens projection values",
        "wave_id": "str -- current execution wave",
        "payload": "dict -- thread-specific state data",
        "checksum": "str -- SHA256 of canonical serialization"
      },
      "invariant": "checksum(row) must reproduce on replay"
    },
    "PacketSynapse": {
      "version": "v1",
      "description": "The unit of inter-thread communication: a typed message between board rows",
      "fields": {
        "source_thread": "str",
        "target_thread": "str",
        "packet_type": "enum: DATA | SYNC | GATE | CERT",
        "sfcr_route": "str -- bridge path (e.g. 'SF->FC')",
        "payload": "dict",
        "timestamp": "float -- epoch seconds",
        "conservation_check": "bool -- all 6 laws verified"
      },
      "routing_rule": "Packets follow shortest SFCR bridge path with live-lock alignment"
    },
    "HeadTransition": {
      "version": "v1",
      "description": "A single state transition of the execution head (Turing head on crystal tape)",
      "fields": {
        "from_address": "str -- crystal address before move",
        "to_address": "str -- crystal address after move",
        "move_primitive": "str -- one of 10 legal moves",
        "legality_cert": "dict -- 3 invariant checks",
        "energy_delta": "float -- conservation balance change",
        "clock_cost": "int -- beats consumed"
      },
      "constraint": "Every transition must pass check_route_legality"
    },
    "LiveSessionTrace": {
      "version": "v1",
      "description": "A complete execution trace: ordered sequence of head transitions forming one session",
      "fields": {
        "session_id": "str -- unique session identifier",
        "start_beat": "int -- master clock start",
        "end_beat": "int -- master clock end",
        "transitions": "list[HeadTransition]",
        "board_snapshots": "list[BoardStateRow] -- sampled at key beats",
        "packets_sent": "list[PacketSynapse]",
        "conservation_balance": "dict -- net balance of all 6 laws"
      },
      "property": "A valid trace has zero net conservation balance"
    },
    "TraceCert": {
      "version": "v1",
      "description": "Certificate proving a trace is lawful: can be verified without replaying",
      "fields": {
        "session_id": "str",
        "trace_hash": "str -- SHA256 of serialized trace",
        "conservation_proof": "dict -- per-law proof witnesses",
        "legality_proof": "dict -- per-transition invariant witnesses",
        "signed_by": "str -- element lobe that certified",
        "timestamp": "float"
      },
      "verification": "verify(cert, trace) -> bool in O(n) where n = transitions"
    },
    "ContinuationSeed": {
      "version": "v1",
      "description": "The minimal restart token: enough state to resume from any certified trace",
      "fields": {
        "seed_id": "str",
        "last_cert": "TraceCert",
        "board_state": "BoardStateRow -- final row",
        "next_address": "str -- crystal address to resume from",
        "live_lock_class": "str -- current lock class (L3-L420)",
        "sfcr_position": "int (1-15) -- current lattice station",
        "helm_wheels": "dict -- 3D/5D/7D wheel positions",
        "continuation_type": "enum: RESUME | FORK | MERGE | SEED"
      },
      "property": "Given a seed and the crystal, replay produces identical trace"
    }
  },
